<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" styleClass="main-content" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ecommerce.ui.screen.CartController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="content-title" text="🛒  Your Shopping Cart" />

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <padding>
            <Insets bottom="10.0" />
        </padding>
        <TextField fx:id="searchField" onKeyReleased="#filterAndDisplay" prefWidth="250.0" promptText="🔍 Search items in cart..." />
        <ComboBox fx:id="sortCombo" onAction="#filterAndDisplay" prefWidth="180.0" promptText="Sort By" />
        <Button onAction="#loadCart" styleClass="button-primary" text="🔄 Refresh" />
    </HBox>

    <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
        <placeholder>
            <Label styleClass="label-muted" text="Your cart is empty." />
        </placeholder>
    </TableView>

    <HBox alignment="CENTER" spacing="15.0" styleClass="pagination-bar">
        <Button onAction="#handlePrevPage" text="◀ Previous" />
        <Label fx:id="pageLabel" styleClass="page-label" text="Page 1 of 1" />
        <Button onAction="#handleNextPage" text="Next ▶" />
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="20.0">
        <padding>
            <Insets top="20.0" />
        </padding>
        <Label fx:id="totalLabel" styleClass="label-bright" text="Total: $0.00">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>
        <Button onAction="#handleCheckout" style="-fx-padding: 12 30; -fx-font-size: 16px;" styleClass="button-success" text="Checkout Now" />
    </HBox>
</VBox>
