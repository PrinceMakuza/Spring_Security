<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" styleClass="main-content" style="-fx-background-color: #1e1e2f;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ecommerce.ui.screen.OrderHistoryController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="📜  Order History" fx:id="titleLabel" style="-fx-text-fill: white;">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <padding>
            <Insets bottom="10.0" top="10.0" />
        </padding>
        <TextField fx:id="searchField" onKeyReleased="#filterAndDisplay" prefWidth="220.0" promptText="🔍 Search by Order ID..." />
        <ComboBox fx:id="sortCombo" onAction="#filterAndDisplay" prefWidth="180.0" promptText="Sort By" />
        <Button onAction="#loadOrders" styleClass="button-secondary" text="🔄 Refresh" />
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox fx:id="ordersContainer" spacing="15.0" />
    </ScrollPane>

    <HBox alignment="CENTER" spacing="15.0" styleClass="pagination-bar">
        <Button onAction="#handlePrevPage" text="◀ Previous" />
        <Label fx:id="pageLabel" styleClass="page-label" text="Page 1 of 1" />
        <Button onAction="#handleNextPage" text="Next ▶" />
    </HBox>
</VBox>
